{
  "name": "nginx-web",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng s -o",
    "build": "ng b",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "hmr": "ng s -o --hmr",
    "analyze": "ng b --source-map",
    "analyze:view": "source-map-explorer dist/**/*.js --no-border-checks",
    "test-coverage": "ng test -c coverage --coverage --watch=false",
    "color-less": "ng-alain-plugin-theme -t=colorLess",
    "theme": "ng-alain-plugin-theme -t=themeCss",
    "icon": "ng g ng-alain:plugin icon",
    "lint": "npm run lint:ts && npm run lint:style",
    "lint:ts": "ng lint",
    "lint:style": "npx stylelint \"src/**/*.less\" --fix",
    "prepare": "husky install"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.2.8",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ant-design/icons-angular": "^21.0.0",
    "@delon/abc": "^21.1.0",
    "@delon/acl": "^21.1.0",
    "@delon/auth": "^21.1.0",
    "@delon/cache": "^21.1.0",
    "@delon/chart": "^21.1.0",
    "@delon/form": "^21.1.0",
    "@delon/theme": "^21.1.0",
    "@delon/util": "^21.1.0",
    "echarts": "^6.0.0",
    "icons": "link:@ant-design/icons-angular/icons",
    "ng-alain": "^21.1.0",
    "ng-zorro-antd": "^21.2.0",
    "rxjs": "~7.8.0",
    "screenfull": "^6.0.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.0",
    "@delon/testing": "^21.1.0",
    "@eslint/js": "^9.39.3",
    "@ng-util/monaco-editor": "^21.1.0",
    "@playwright/test": "^1.57.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@typescript-eslint/utils": "^8.57.2",
    "@vitest/browser-playwright": "^4.0.17",
    "@vitest/coverage-v8": "^4.0.16",
    "angular-eslint": "^21.3.1",
    "date-fns": "^4.1.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "~2.32.0",
    "eslint-plugin-jsdoc": "~62.8.1",
    "eslint-plugin-prefer-arrow": "~1.2.3",
    "eslint-plugin-prettier": "~5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "less": "^4.2.0",
    "lint-staged": "^16.3.2",
    "ng-alain": "^21.1.0",
    "ng-alain-plugin-theme": "^18.0.0",
    "ngx-tinymce": "^21.0.0",
    "prettier": "^3.8.1",
    "source-map-explorer": "^2.5.3",
    "stylelint": "^17.6.0",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-block-no-ignored-properties": "^3.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "(src)/**/*.{html,ts}": [
      "eslint --fix"
    ],
    "(src)/**/*.less": [
      "npm run lint:style"
    ]
  }
}
